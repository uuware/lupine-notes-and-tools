{
  "name": "lupine-notes-and-tools",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "apps/*/*",
    "packages/*"
  ],
  "scripts": {
    "app1:build-win": "electron-builder --win --config apps/lupine-notes-and-tools/electron/builder.json",
    "app1:build-linux": "electron-builder --linux --config apps/lupine-notes-and-tools/electron/builder.json",
    "app1:build-mac": "export CSC_IDENTITY_AUTO_DISCOVERY=true && electron-builder --mac --x64 --config apps/lupine-notes-and-tools/electron/builder.json",
    "app1:unpack-mac": "npx asar extract dist/build/mac-arm64-unpacked/lupine-notes-and-tools.app/Contents/Resources/app.asar dist/build/mac-arm64-unpacked/lupine-notes-and-tools.app/Contents/Resources/app.asar-unpack",
    "app1:unpack-linux": "npx asar extract dist/build/linux-arm64-unpacked/resources/app.asar dist/build/linux-arm64-unpacked/resources/app.asar-unpack",
    "app1:unpack-win": "npx asar extract dist/build/win-unpacked/resources/app.asar dist/build/win-unpacked/resources/app.asar-unpack",
    "app1:desktop": "electron apps/lupine-notes-and-tools/electron/main.js",
    "app1:sync": "npm run sync --workspace=lupine-notes-and-tools-web",
    "app1:open-ios": "npm run open-ios --workspace=lupine-notes-and-tools-web",
    "app1:open-android": "npm run open-android --workspace=lupine-notes-and-tools-web",
    "app1:run-ios": "npm run run-ios --workspace=lupine-notes-and-tools-web",
    "app1:run-android": "npm run run-android --workspace=lupine-notes-and-tools-web",
    "dev": "node ./dev/dev-watch --env=.env.development --dev=1 --cmd=start-dev",
    "build": "node ./dev/dev-watch --env=.env.production --dev=0 --obfuscate=0",
    "build-mobile": "node ./dev/dev-watch --env=.env.mobile --dev=0 --mobile=1",
    "start-dev": "node dist/server_root/server/app-loader.js --env=.env.development",
    "start-production": "node dist/server_root/server/app-loader.js --env=.env.production",
    "cp-docs": "node dev/cp-folder.js dist/server_root/lupine-notes-and-tools_web/lupine-notes-and-tools docs",
    "format": "prettier --write \"**/*.{js,json,css,scss,md,html,yaml,ts,jsx,tsx}\""
  },
  "dependencies": {
    "lupine.api": "^1.1.82",
    "lupine.components": "^1.1.35",
    "lupine.web": "^1.1.16"
  },
  "devDependencies": {
    "esbuild": "^0.24.2",
    "electron": "^35.2.0",
    "electron-builder": "^26.0.12",
    "typescript": "^5.7.2",
    "@types/node": "^22.10.5",
    "prettier": "^2.7.1"
  }
}
